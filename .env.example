# HermesHQ Environment Configuration
# Copy this file to .env and adjust values for your deployment.

# Concurrency — max concurrent task runner processes (default: 8)
# Each process uses ~50MB RAM. For sizing: available_RAM_MB / 60
CONCURRENCY_SEMAPHORE=8

# Database
POSTGRES_DB=hermeshq
POSTGRES_USER=hermeshq
POSTGRES_PASSWORD=hermeshq

# Backend
JWT_SECRET=change-me
AUTH_MODE=local
BACKEND_PORT=8000
FRONTEND_PORT=3420
PUBLIC_BASE_URL=https://hq.gcaplabs.com
CONTAINER_HOST_URL=
# Per-instance runtime host: instances resolve to https://hm-<id>.RUN_DOMAIN
# Use the apex zone (gcaplabs.com) so instances are single-level subdomains
# (hm-<id>.gcaplabs.com), covered by Cloudflare's free universal *.gcaplabs.com
# cert. A second-level zone like run.gcaplabs.com would need paid Advanced Cert.
RUN_DOMAIN=gcaplabs.com
FORWARD_AUTH_HMAC_SECRET=change-me-generate-with-openssl-rand-hex-32
FORWARD_AUTH_TOKEN_TTL_SECONDS=86400
FORWARD_AUTH_URL=http://127.0.0.1:18081/
RUNTIME_CONTAINER_IMAGE=headmaster-hermes-runtime:latest
RUNTIME_CONTAINER_NETWORK=hermes_runtime
RUNTIME_CONTAINER_IDLE_TTL_SECONDS=3600
RUNTIME_CONTAINER_CPU=2
RUNTIME_CONTAINER_MEMORY=4g
RUNTIME_CONTAINER_PIDS_LIMIT=512
RUNTIME_CONTAINER_SHM_SIZE=1g
RUNTIME_CONTAINER_TRAEFIK_MIDDLEWARE=headmaster-forward-auth@docker
# Optional: when Traefik Docker provider is unavailable, write per-runtime
# routes into a file-provider config mounted into Traefik.
RUNTIME_TRAEFIK_DYNAMIC_CONFIG_PATH=
RUNTIME_TRAEFIK_DYNAMIC_CONFIG_HOST_PATH=/tmp/headmaster-runtimes.yml
