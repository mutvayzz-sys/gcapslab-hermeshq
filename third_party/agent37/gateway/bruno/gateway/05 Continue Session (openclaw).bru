meta {
  name: 05 Continue Session (openclaw)
  type: http
  seq: 5
}

post {
  url: {{baseUrl}}/v1/responses
  body: json
  auth: none
}

headers {
  Content-Type: application/json
}

body:json {
  {
    "session_id": "{{openclawSessionId}}",
    "input": "In one short sentence, what did I just ask you to say?",
    "agent": "openclaw",
    "reasoning_effort": "low"
  }
}

tests {
  test("returns 200", function () {
    expect(res.status).to.equal(200);
  });

  test("same session, completed", function () {
    expect(res.body.session_id).to.equal(bru.getEnvVar("openclawSessionId"));
    expect(res.body.status).to.equal("completed");
    expect(res.body.agent).to.equal("openclaw");
  });
}

docs {
  Continue an OpenClaw conversation. Reuses `openclawSessionId` saved by
  "04 Create Response (openclaw)". Always include `"agent": "openclaw"` so the
  gateway routes the turn to the right backend.
}
